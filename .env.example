# ─── Auth / Google OAuth ──────────────────────────────────
# Required for Google Login system
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
JWT_SECRET=generate_strong_secret_with_openssl_rand_hex_32

# ─── LLM — hosted SaaS (recommended) ─────────────────────────────────
# Put ONE server-side key here — never expose in the browser / VITE_*.
# OpenRouter: https://openrouter.ai — many models; comma list = cascade order.
OPENROUTER_API_KEY=
# Optional: production site URL + name (OpenRouter analytics / rankings)
# OPENROUTER_HTTP_REFERER=https://yourdomain.com
# OPENROUTER_APP_TITLE=ShieldSentinel
# OPENROUTER_MODELS=qwen/qwen3-coder:free,meta-llama/llama-3.3-70b-instruct:free,openai/gpt-oss-120b:free
# OPENROUTER_FALLBACK_MODEL=qwen/qwen3-coder:free

# Optional second cloud tier (fast, cheap) — used if OpenRouter errors out
# GROQ_API_KEY=
# GROQ_MODELS=llama-3.3-70b-versatile,openai/gpt-oss-120b

# ─── LLM — free local Ollama in Docker ────────────────────────────────
# Default in docker-compose.ollama.yml is llama3.2:1b (~1–1.5GB) for low RAM.
# If you have ~6GB total system RAM, add docker-compose.lowram.yml so ZAP does not start
# (ZAP alone can use several GB of Java heap):
#
#   docker compose -f docker-compose.yml -f docker-compose.ollama.yml -f docker-compose.lowram.yml up -d
#   docker compose ... exec ollama ollama pull llama3.2:1b
#
# Even smaller (weaker quality): tinyllama, qwen2.5:0.5b
# If you have 16GB+ RAM you can use larger models, e.g.:
# OLLAMA_MODEL=llama3.2
# OLLAMA_MODEL=qwen2.5-coder:7b
#
# Without docker-compose.ollama.yml: set USE_LOCAL_LLM=1, LLM_LOCAL_FIRST=1, and point
# OLLAMA_BASE_URL at your host (e.g. http://host.docker.internal:11434/v1 on Docker Desktop Mac).
#
# For hosted SaaS with a shared OpenRouter key, omit docker-compose.ollama.yml and leave
# LLM_LOCAL_FIRST unset (cloud runs first; Ollama can stay as optional fallback only).

# ─── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:1234@postgres:5432/shieldssentinel

# ─── Queue / Cache ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── Security Tools ───────────────────────────────────────────────
ZAP_URL=http://zap:8090

# ─── Storage ──────────────────────────────────────────────────────
UPLOAD_DIR=/tmp/shieldssentinel_uploads
